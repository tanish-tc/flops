FROM python:3.11-slim
WORKDIR /app

# 1. Force the tiny CPU-only version of PyTorch first!
RUN pip install --no-cache-dir torch --extra-index-url https://download.pytorch.org/whl/cpu

# 2. Now install the rest of the stack
RUN pip install --no-cache-dir fastapi uvicorn transformers optimum[onnxruntime]

# 3. Copy the hybrid model folder
COPY onnx_quantized_model/ ./onnx_quantized_model/
COPY app_onnx_quant.py .

CMD ["uvicorn", "app_onnx_quant:app", "--host", "0.0.0.0", "--port", "8004"]

